{
  "expo": {
    "name": "Jockey Copilot",
    "slug": "cars24-jockey-copilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jockey-copilot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.cars24.jockeycopilot",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Jockey Copilot uses the camera to guide vehicle inspection photos in real time.",
        "NSMicrophoneUsageDescription": "Jockey Copilot uses the microphone for voice notes and guided engine-sound checks.",
        "UIBackgroundModes": [
          "voip"
        ]
      }
    },
    "android": {
      "package": "com.cars24.jockeycopilot",
      "adaptiveIcon": {
        "backgroundColor": "#101820",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "@daily-co/config-plugin-rn-daily-js",
        {
          "enableCamera": true,
          "enableMicrophone": true,
          "enableScreenShare": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#101820",
          "dark": {
            "backgroundColor": "#101820"
          }
        }
      ]
    ],
    "extra": {
      "productName": "Cars24 Jockey Copilot",
      "demoVehicleRegistration": "KA03MX2147"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
